---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Header } from '@/components/guaufresh/Header';
import { HeroCarousel } from '@/components/guaufresh/HeroCarousel';
import { Benefits } from '@/components/guaufresh/Benefits';
import { Product } from '@/components/guaufresh/Product';
import { PetCalculator } from '@/components/guaufresh/PetCalculator';
import { HowToUse } from '@/components/guaufresh/HowToUse';
import { Reviews } from '@/components/guaufresh/Reviews';
import { Faq } from '@/components/guaufresh/Faq';
import { Contact } from '@/components/guaufresh/Contact';
import { Footer } from '@/components/guaufresh/Footer';
import { CartSheet } from '@/components/guaufresh/CartSheet';
import { WhatsAppButton } from '@/components/guaufresh/WhatsAppButton';
import { StickyCTA } from '@/components/guaufresh/StickyCTA';
import { PromoPopup } from '@/components/guaufresh/PromoPopup';
import { LeadSidebar } from '@/components/guaufresh/LeadSidebar';
import { StructuredData } from '@/components/guaufresh/StructuredData';
import { ChatBot } from '@/components/guaufresh/ChatBot';
import { BubbleEffect } from '@/components/guaufresh/BubbleEffect';
---

<BaseLayout title="Limpiador de Patas para Perros - Remueve Barro y Suciedad en Segundos">
  <StructuredData />
  <div class="relative min-h-screen">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-primary focus:px-4 focus:py-2 focus:text-primary-foreground"
    >
      Saltar al contenido principal
    </a>
    <Header client:load />
    <main id="main-content" class="relative z-10">
      <HeroCarousel client:load />
      <Benefits client:visible />
      <Product client:visible />
      <PetCalculator client:visible />
      <HowToUse client:visible />
      <Reviews client:visible />
      <Faq client:visible />
      <Contact client:visible />
    </main>
    <Footer />
    <CartSheet client:load />
    <WhatsAppButton />
    <ChatBot client:load />
    <PromoPopup client:load />
    <LeadSidebar client:load />
    <BubbleEffect client:load />
    <StickyCTA client:load />
  </div>
</BaseLayout>
